# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # set to 'production' for deployed instances
LOG_LEVEL=info                # 'debug' | 'info' | 'warn' | 'error'

# ── Security ──────────────────────────────────────────────────────────────────
# MUST be a strong random secret in production. Server refuses to start if unset.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_jwt_secret_here

# Set to 'true' ONLY in development/staging — enables offline fallbacks for DB/AI
ALLOW_DEMO_AUTH=true

# In production, set to your deployed frontend URL (e.g. https://app.tresk.ai)
# Cannot be "*" in production.
CORS_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/tresk_ai
# Individual vars (used by docker-compose.yml substitution):
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=tresk_ai
PG_USER=postgres
PG_PASSWORD=your_db_password_here      # Change this! Never use 'password' in production
PG_SSL=false                           # Set 'true' for cloud DBs (Supabase, Neon, Railway)

# ── Redis ──────────────────────────────────────────────────────────────────────
# Used by docker-compose for BullMQ, OpenRouter response cache, Socket.IO adapter
REDIS_URL=redis://:changeme_redis@localhost:6379
REDIS_PASSWORD=changeme_redis          # Change this!

# ── AI Services ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
GEMINI_API_KEY=your_gemini_api_key_here    # optional: used for embeddings + RAG

# ── Code Execution (Piston API) ───────────────────────────────────────────────
# Uses the public Piston API by default (free, no key needed).
# For production, self-host Piston: https://github.com/engineer-man/piston
# PISTON_API_URL=https://emkc.org/api/v2/piston   # default (public)
# PISTON_API_URL=https://your-piston.example.com/api/v2/piston  # self-hosted

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
# MUST be real keys in production — server refuses to start if unset.
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Razorpay webhook secret — set in Razorpay Dashboard → Settings → Webhooks
# Required for the /api/billing/webhook endpoint to verify event authenticity
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Optional: Razorpay Subscription Plan IDs (for recurring billing)
# RAZORPAY_PRO_PLAN_ID=plan_XXXXXXXXXXXXXXXX
# RAZORPAY_TEAMS_PLAN_ID=plan_XXXXXXXXXXXXXXXX

# ── Email Service ─────────────────────────────────────────────────────────────
# Choose your email provider: 'resend' | 'sendgrid' | 'smtp' | 'console'
# 'console' logs emails to stdout (useful for development, no keys needed)
EMAIL_PROVIDER=console
EMAIL_FROM=TRESK AI <noreply@tresk.ai>
APP_BASE_URL=http://localhost:5173   # Used in email links — set to your frontend URL

# Resend (recommended — free 3K/month): https://resend.com
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SendGrid: https://sendgrid.com
# SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SMTP (Gmail, Zoho, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password

# ── Optional: Firebase (for Google OAuth only) ────────────────────────────────
# VITE_FIREBASE_API_KEY is set in the frontend .env, not here.
# The backend only validates Firebase ID tokens — no SDK setup needed.
